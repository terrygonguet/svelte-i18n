{
	"name": "@terrygonguet/svelte-i18n",
	"version": "0.1.0",
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./editor": {
			"types": "./dist/editor.svelte.d.ts",
			"svelte": "./dist/editor.svelte.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"svelte": "./dist/server.js"
		},
		"./I18NEditorDialog.svelte": {
			"types": "./dist/I18NEditorDialog.svelte.d.ts",
			"svelte": "./dist/I18NEditorDialog.svelte"
		}
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.0.0",
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@rollup/pluginutils": "^5.3.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/better-sqlite3": "^7.6.13",
		"better-sqlite3": "^12.8.0",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.1",
		"highlight.js": "^11.11.1",
		"marked": "^17.0.5",
		"marked-custom-heading-id": "^2.0.16",
		"marked-highlight": "^2.2.3",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"publint": "^0.3.18",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^8.0.2"
	},
	"dependencies": {
		"@terrygonguet/utils": "^0.11.0"
	},
	"keywords": [
		"svelte",
		"i18n"
	],
	"author": {
		"email": "terry@gonguet.com",
		"name": "Terry Gonguet",
		"url": "https://terry.gonguet.com/"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/terrygonguet/svelte-i18n.git"
	},
	"bugs": {
		"url": "https://github.com/terrygonguet/svelte-i18n/issues"
	}
}
