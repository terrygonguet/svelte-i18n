{
	"name": "@terrygonguet/svelte-i18n",
	"version": "1.0.0-gamma.3",
	"license": "MIT",
	"scripts": {
		"dev": "nodemon --exec \"npm run build\" --watch src --ext ts,svelte,html",
		"build": "vite build && npm run prepack",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./editor": {
			"types": "./dist/editor.svelte.d.ts",
			"svelte": "./dist/editor.svelte.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"svelte": "./dist/server.js"
		},
		"./I18NEditorDialog.svelte": {
			"types": "./dist/I18NEditorDialog.svelte.d.ts",
			"svelte": "./dist/I18NEditorDialog.svelte"
		}
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.58.0",
		"svelte": "^5.55.1"
	},
	"devDependencies": {
		"@rollup/pluginutils": "^5.3.0",
		"@standard-schema/spec": "^1.1.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"nodemon": "^3.1.14",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"publint": "^0.3.18",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.3",
		"vite": "^8.0.10"
	},
	"dependencies": {
		"@terrygonguet/utils": "^0.11.0"
	},
	"keywords": [
		"svelte",
		"i18n"
	],
	"author": {
		"email": "terry@gonguet.com",
		"name": "Terry Gonguet",
		"url": "https://terry.gonguet.com/"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/terrygonguet/svelte-i18n.git"
	},
	"bugs": {
		"url": "https://github.com/terrygonguet/svelte-i18n/issues"
	}
}
